# =========================================================
# Autowit AI Platform — Environment Variables
# Copy to .env and fill in all values before deploying
# =========================================================

# ── App ───────────────────────────────────────────────────
NODE_ENV=production
APP_PORT=3001
FRONTEND_URL=https://autowit.me
AUTOWIT_API_KEY=aw_prod_key_change_me_2026

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
JWT_EXPIRES_IN=7d

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://autowit:autowit_pass@127.0.0.1:5432/autowit_db
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=autowit_db
DB_USER=autowit
DB_PASS=autowit_pass

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── OpenAI (Tier 1) ───────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_PREMIUM=gpt-4o

# ── Anthropic Claude (Tier 2) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Ollama (Tier 0 — local free) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAB...
TELEGRAM_WEBHOOK_SECRET=autowit_wh_secret_2026

# ── n8n Integration ───────────────────────────────────────
N8N_BASE_URL=http://127.0.0.1:5678
N8N_API_KEY=
N8N_WEBHOOK_URL=https://autowit.me/n8n

# ── Channels ──────────────────────────────────────────────
# Telegram (already configured above)

# WhatsApp Business Cloud API
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Zalo Official Account
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ACCESS_TOKEN=
ZALO_WEBHOOK_SECRET=

# Facebook Messenger
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=

# X / Twitter
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# YouTube
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Notion
NOTION_INTEGRATION_TOKEN=
NOTION_DATABASE_ID=

# ── Cost Control ──────────────────────────────────────────
DAILY_COST_ALERT_USD=2.0

# ── Semantic Cache ────────────────────────────────────────
# TTL for cached AI responses (seconds)
CACHE_TTL_SIMPLE=300
CACHE_TTL_HEAVY=1800

# ── Next.js (set in frontend/.env.local) ─────────────────
NEXT_PUBLIC_API_URL=https://autowit.me/api
NEXT_PUBLIC_APP_NAME=Autowit
