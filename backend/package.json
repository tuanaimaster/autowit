{
  "name": "autowit-api",
  "version": "0.1.0",
  "description": "Autowit AI Automation Platform — NestJS API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "migration:run": "npm run build && typeorm migration:run -d dist/data-source.js",
    "migration:revert": "npm run build && typeorm migration:revert -d dist/data-source.js",
    "migration:show": "npm run build && typeorm migration:show -d dist/data-source.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/bull": "^10.1.1",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/throttler": "^5.1.1",
    "typeorm": "^0.3.19",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "bull": "^4.12.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "bcrypt": "^5.1.1",
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.18.0",
    "telegraf": "^4.16.3",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "axios": "^1.6.7",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.6",
    "@types/bcrypt": "^5.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/bull": "^4.10.0",
    "@types/uuid": "^9.0.7",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "jest": "^29.7.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
